generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum ProviderMode {
  BUILT_IN
  CUSTOM
}

enum GenerationStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum GenerationType {
  TEXT_TO_IMAGE
  IMAGE_TO_IMAGE
}

enum ShowcaseStatus {
  PRIVATE
  PENDING
  FEATURED
  TAKEDOWN_PENDING
}

enum RedeemCodeMode {
  SINGLE_USE
  SHARED
}

model User {
  id                   String               @id @default(cuid())
  email                String               @unique
  passwordHash         String?
  nickname             String?
  avatarUrl            String?
  oauthProvider        String?
  oauthId              String?
  role                 Role                 @default(USER)
  credits              Int                  @default(500)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  inviteUsed           InviteCode?          @relation("InviteUsedBy")
  inviteBatches        InviteBatch[]        @relation("InviteBatchCreatedBy")
  createdInvites       InviteCode[]         @relation("InviteCreatedBy")
  customProviderConfig SavedProviderConfig?
  checkInRecords       CheckInRecord[]
  generations          GenerationJob[]
  featuredGenerations  GenerationJob[]      @relation("FeaturedByAdmin")
  reviewedWorks        GenerationImage[]    @relation("ReviewedWorks")
  likedWorks           WorkLike[]
  redeemBatches        RedeemCodeBatch[]    @relation("RedeemBatchCreatedBy")
  createdRedeemCodes   RedeemCode[]         @relation("RedeemCodeCreatedBy")
  redeemRedemptions    RedeemRedemption[]

  @@index([oauthProvider, oauthId])
}

model InviteBatch {
  id          String       @id @default(cuid())
  title       String?
  isPublic    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdById String?
  createdBy   User?        @relation("InviteBatchCreatedBy", fields: [createdById], references: [id])
  inviteCodes InviteCode[]
}

model BenefitConfig {
  id                  String   @id @default(cuid())
  scope               String   @unique @default("default")
  checkInReward       Int      @default(50)
  autoApproveShowcase Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TurnstileConfig {
  id                  String   @id @default(cuid())
  scope               String   @unique @default("default")
  isEnabled           Boolean  @default(false)
  siteKey             String?
  secretEncrypted     String?
  protectLogin        Boolean  @default(true)
  protectRegister     Boolean  @default(true)
  protectInviteRedeem Boolean  @default(true)
  protectGenerate     Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model OAuthProvider {
  id           String   @id @default(cuid())
  type         String   @unique
  displayName  String
  clientId     String
  clientSecret String
  isEnabled    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model CheckInRecord {
  id            String   @id @default(cuid())
  userId        String
  dateKey       String
  rewardCredits Int
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
}

/// @deprecated — 旧表保留避免 prisma db push 数据丢失，新逻辑已迁移至 ProviderChannel
model BuiltInProviderConfig {
  id              String   @id @default(cuid())
  scope           String   @unique @default("default")
  name            String
  baseUrl         String
  apiKeyEncrypted String
  model           String
  models          String[] @default([])
  creditCost      Int      @default(5)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ProviderChannel {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  baseUrl         String
  apiKeyEncrypted String
  defaultModel    String
  models          String[] @default([])
  creditCost      Int      @default(5)
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model InviteCode {
  id          String       @id @default(cuid())
  code        String       @unique
  note        String?
  batchId     String?
  claimedAt   DateTime?
  createdAt   DateTime     @default(now())
  usedAt      DateTime?
  createdById String?
  usedById    String?      @unique
  batch       InviteBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  createdBy   User?        @relation("InviteCreatedBy", fields: [createdById], references: [id])
  usedBy      User?        @relation("InviteUsedBy", fields: [usedById], references: [id])
}

model WorkLike {
  id        String          @id @default(cuid())
  workId    String
  userId    String
  createdAt DateTime        @default(now())
  work      GenerationImage @relation(fields: [workId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workId, userId])
  @@index([userId])
  @@index([workId])
}

model RedeemCodeBatch {
  id             String         @id @default(cuid())
  title          String?
  mode           RedeemCodeMode @default(SINGLE_USE)
  rewardCredits  Int
  maxRedemptions Int?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  createdById    String?
  createdBy      User?          @relation("RedeemBatchCreatedBy", fields: [createdById], references: [id])
  codes          RedeemCode[]
}

model RedeemCode {
  id             String             @id @default(cuid())
  code           String             @unique
  note           String?
  mode           RedeemCodeMode
  rewardCredits  Int
  maxRedemptions Int
  redeemedCount  Int                @default(0)
  isActive       Boolean            @default(true)
  batchId        String?
  createdById    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  batch          RedeemCodeBatch?   @relation(fields: [batchId], references: [id], onDelete: Cascade)
  createdBy      User?              @relation("RedeemCodeCreatedBy", fields: [createdById], references: [id])
  redemptions    RedeemRedemption[]

  @@index([batchId])
  @@index([isActive])
}

model RedeemRedemption {
  id            String     @id @default(cuid())
  codeId        String
  userId        String
  rewardCredits Int
  createdAt     DateTime   @default(now())
  code          RedeemCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([codeId, userId])
  @@index([userId])
  @@index([codeId])
}

model SavedProviderConfig {
  id              String   @id @default(cuid())
  userId          String   @unique
  label           String?
  baseUrl         String
  apiKeyEncrypted String
  model           String
  models          String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GenerationJob {
  id              String            @id @default(cuid())
  userId          String
  generationType  GenerationType    @default(TEXT_TO_IMAGE)
  providerMode    ProviderMode
  model           String
  prompt          String
  negativePrompt  String?
  size            String
  quality         String            @default("auto")
  outputFormat    String            @default("png")
  outputCompression Int?
  moderation      String            @default("auto")
  sourceImageUrls String[]          @default([])
  count           Int
  status          GenerationStatus  @default(PENDING)
  errorMessage    String?
  creditsSpent    Int               @default(0)
  featuredAt      DateTime?
  featuredById    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  featuredBy      User?             @relation("FeaturedByAdmin", fields: [featuredById], references: [id])
  images          GenerationImage[]
}

model GenerationImage {
  id               String         @id @default(cuid())
  jobId            String
  url              String
  width            Int?
  height           Int?
  showcaseStatus   ShowcaseStatus @default(PRIVATE)
  showPromptPublic Boolean        @default(false)
  submittedAt      DateTime?
  featuredAt       DateTime?
  reviewedAt       DateTime?
  reviewNote       String?
  reviewedById     String?
  createdAt        DateTime       @default(now())
  job              GenerationJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  reviewedBy       User?          @relation("ReviewedWorks", fields: [reviewedById], references: [id])
  likes            WorkLike[]
}
