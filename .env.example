# ===== 必填 =====
# PostgreSQL 连接串
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# 会话签名 + 渠道密钥加密所用密钥；至少 10 位的强随机字符串
# 可用：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" 生成
AUTH_SECRET=replace-with-strong-random-string-at-least-10-chars

# 站点对外 URL（用于回跳、邮件链接等）
APP_URL=http://localhost:3000

# ===== 首次启动用 =====
# 满足该邮箱的注册会自动获得管理员角色
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# 初始邀请码（首次注册时若不存在会自动写入数据库）
BOOTSTRAP_INVITE_CODE=FOUNDING-ACCESS

# ===== 内置生图渠道（兜底，可选；后台也可动态配置渠道） =====
BUILTIN_PROVIDER_BASE_URL=https://api.openai.com/v1
BUILTIN_PROVIDER_API_KEY=sk-replace-me
BUILTIN_PROVIDER_MODEL=gpt-image-2
BUILTIN_PROVIDER_CREDIT_COST=5
BUILTIN_PROVIDER_NAME=Studio

# ===== 对象存储（推荐 Cloudflare R2） =====
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_BUCKET=your-bucket-name
# 对象的公开访问域名（CDN / R2 自定义域名）
S3_PUBLIC_BASE_URL=https://your-cdn-domain

# ===== 行为开关 =====
# S3 上传失败时是否回退到本地图片缓存
ENABLE_LOCAL_IMAGE_FALLBACK=true

# ===== Docker Compose 相关（可选，仅 docker-compose.yaml 使用） =====
POSTGRES_DB=narra
POSTGRES_USER=narra
POSTGRES_PASSWORD=replace-me
POSTGRES_PORT=5432
APP_PORT=3000
